generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// Modelos requeridos por el adapter de Auth.js — no tocar nombres/campos.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Usuario de la comunidad DALIA.EXE.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  points        Int       @default(0)

  // Vínculo con League of Legends (Riot API)
  riotPuuid      String?  @unique
  riotGameName   String?
  riotTagLine    String?
  riotRegion     String? // EUW | NA | LAN | LAS
  riotVerified   Boolean  @default(false)
  riotVerifiedAt DateTime?

  // Reto de verificación pendiente (comparar icono de invocador)
  pendingChallengeIcon Int?
  pendingChallengeAt   DateTime?

  // Vínculo con Twitch (identidad del viewer)
  twitchId          String?   @unique
  twitchLogin       String?
  twitchProfileImg  String?
  twitchConnectedAt DateTime?

  // Estado de suscripción en el canal de Dalia (se sincroniza contra el token del broadcaster)
  subTier      Int? // 1000 = Tier 1, 2000 = Tier 2, 3000 = Tier 3 (formato Twitch)
  subSince     DateTime?
  subCheckedAt DateTime?

  // Perfil público dentro de la web
  bio         String?
  pronouns    String?
  avatarChamp String? // id de campeón de Data Dragon usado como avatar

  createdAt DateTime @default(now())

  accounts     Account[]
  sessions     Session[]
  lfgPosts     LfgPost[]
  galleryPosts GalleryPost[]
}

// Publicación en la Galería: imagen o clip de video subido por un usuario.
model GalleryPost {
  id        String   @id @default(cuid())
  userId    String
  type      String // image | video | link
  blobKey   String?  @unique
  mimeType  String?
  fileSize  Int?

  // Para posts tipo "link" (Twitch, YouTube, Medal, Overplay...)
  externalUrl   String?
  embedUrl      String? // URL de iframe si la plataforma se puede incrustar
  platformLabel String?

  caption   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Anuncio de "buscar equipo" — el rango/región/Riot ID se toman del perfil
// verificado del autor en el momento de publicar (snapshot, no editable).
model LfgPost {
  id        String   @id @default(cuid())
  userId    String
  role      String
  looking   String
  message   String
  tierSnap  String
  regionSnap String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Token OAuth del canal (broadcaster) de Dalia — fila única, usado para
// consultar su lista de suscriptores vía la API de Twitch.
model BroadcasterToken {
  id           String   @id @default("dalia")
  twitchUserId String
  accessToken  String
  refreshToken String
  scope        String
  updatedAt    DateTime @updatedAt
}

// Horario semanal de directos — editable desde /admin/calendario.
model ScheduleEntry {
  id        String   @id @default(cuid())
  day       String
  time      String
  content   String
  type      String // stream | special | event | off
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Sorteo de la tienda — editable desde /admin/sorteos.
model Raffle {
  id         String   @id @default(cuid())
  name       String
  category   String // Merch | Riot | Periféricos | Especial
  cost       Int
  maxEntries Int
  entries    Int      @default(0)
  closes     String
  image      String?
  active     Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

// Donación registrada manualmente por un admin (sin integración de pago real).
model Donor {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  currency  String   @default("USD")
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// Torneo activo — editable desde /admin/torneo.
model Tournament {
  id            String   @id @default(cuid())
  name          String
  format        String
  date          String
  maxTeams      Int
  prize         String
  patch         String
  checkinOpen   Boolean  @default(false)
  checkinCloses String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  teams   TournamentTeam[]
  matches BracketMatch[]
}

model TournamentTeam {
  id           String   @id @default(cuid())
  tournamentId String
  name         String
  captain      String
  avgRank      String
  checkedIn    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  tournament Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchesA   BracketMatch[] @relation("TeamA")
  matchesB   BracketMatch[] @relation("TeamB")
}

// Casilla del cuadro de eliminación. round: 1 = cuartos, 2 = semis, 3 = final.
model BracketMatch {
  id           String   @id @default(cuid())
  tournamentId String
  round        Int
  slot         Int
  teamAId      String?
  teamBId      String?
  scoreA       Int      @default(0)
  scoreB       Int      @default(0)
  state        String   @default("pendiente") // pendiente | en_juego | terminada
  hora         String

  tournament Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA      TournamentTeam? @relation("TeamA", fields: [teamAId], references: [id])
  teamB      TournamentTeam? @relation("TeamB", fields: [teamBId], references: [id])
}

model PastTournament {
  id         String   @id @default(cuid())
  name       String
  date       String
  winner     String
  runnerUp   String
  mvp        String
  teamsCount Int
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}
