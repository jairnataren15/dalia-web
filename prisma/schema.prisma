generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// Modelos requeridos por el adapter de Auth.js — no tocar nombres/campos.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Usuario de la comunidad DALIA.EXE.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  points        Int       @default(0)

  // Vínculo con League of Legends (Riot API)
  riotPuuid      String?  @unique
  riotGameName   String?
  riotTagLine    String?
  riotRegion     String? // EUW | NA | LAN | LAS
  riotVerified   Boolean  @default(false)
  riotVerifiedAt DateTime?

  // Reto de verificación pendiente (comparar icono de invocador)
  pendingChallengeIcon Int?
  pendingChallengeAt   DateTime?

  // Vínculo con Twitch (identidad del viewer)
  twitchId          String?   @unique
  twitchLogin       String?
  twitchProfileImg  String?
  twitchConnectedAt DateTime?

  // Estado de suscripción en el canal de Dalia (se sincroniza contra el token del broadcaster)
  subTier      Int? // 1000 = Tier 1, 2000 = Tier 2, 3000 = Tier 3 (formato Twitch)
  subSince     DateTime?
  subCheckedAt DateTime?

  createdAt DateTime @default(now())

  accounts Account[]
  sessions Session[]
}

// Token OAuth del canal (broadcaster) de Dalia — fila única, usado para
// consultar su lista de suscriptores vía la API de Twitch.
model BroadcasterToken {
  id           String   @id @default("dalia")
  twitchUserId String
  accessToken  String
  refreshToken String
  scope        String
  updatedAt    DateTime @updatedAt
}

// Donación registrada manualmente por un admin (sin integración de pago real).
model Donor {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  currency  String   @default("EUR")
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}
